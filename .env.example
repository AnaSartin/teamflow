# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role key — NUNCA expor no front-end. Apenas server-side.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── E-mail (Resend) ────────────────────────────────────────
# Crie conta gratuita em https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remetente (domínio verificado no Resend)
EMAIL_FROM=noreply@suaempresa.com.br

# Destinatário principal dos alertas gerenciais
EMAIL_MANAGER=gestor@suaempresa.com.br

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://teamflow.vercel.app

# Nome da empresa exibido na UI e nos e-mails
NEXT_PUBLIC_COMPANY_NAME=Adaptive

# ─── Cron / Notificações automáticas ───────────────────────
# Segredo para proteger a rota /api/cron/notifications
CRON_SECRET=um_segredo_longo_e_aleatorio_aqui
